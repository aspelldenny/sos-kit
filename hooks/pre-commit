#!/usr/bin/env bash
# sos-kit v2 pre-commit hook
# Install: git config core.hooksPath hooks (or copy to .git/hooks/)
#
# Runs in order:
#   1. Stack-specific type check (auto-detect)
#   2. docs-gate Rust binary (v1 checks: CHANGELOG + ARCHITECTURE 9 sections)
#   3. v2-specific checks: BACKLOG.md, Discovery Report mandatory for new phiếu
#
# Exit non-zero blocks commit. Use `git commit --no-verify` to bypass (not recommended).

set -uo pipefail

FAIL_COUNT=0
WARN_COUNT=0

red()    { printf "\033[31m%s\033[0m\n" "$*"; }
green()  { printf "\033[32m%s\033[0m\n" "$*"; }
yellow() { printf "\033[33m%s\033[0m\n" "$*"; }
blue()   { printf "\033[34m%s\033[0m\n" "$*"; }

blue "🔍 sos-kit v2 pre-commit checks..."
echo ""

# ─────────────────────────────────────────────────────────────────────
# 1. Stack-specific type check (auto-detect)
# ─────────────────────────────────────────────────────────────────────
blue "[1/3] Type check"

if [ -f "Cargo.toml" ]; then
    echo "  → cargo check"
    if ! cargo check --quiet 2>&1 | tail -10; then
        red "  ❌ Cargo check failed"
        FAIL_COUNT=$((FAIL_COUNT + 1))
    else
        green "  ✅ Cargo check passed"
    fi
elif [ -f "package.json" ] && grep -q "type-check" package.json 2>/dev/null; then
    PM=$(test -f pnpm-lock.yaml && echo "pnpm" || echo "npm")
    echo "  → $PM type-check"
    if ! $PM run type-check --silent 2>&1 | tail -5; then
        red "  ❌ Type check failed"
        FAIL_COUNT=$((FAIL_COUNT + 1))
    else
        green "  ✅ Type check passed"
    fi
elif [ -f "pyproject.toml" ] || [ -f "requirements.txt" ]; then
    # Python: syntax-check staged .py files (not full mypy — too slow)
    PY_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)
    if [ -n "$PY_FILES" ]; then
        echo "  → python syntax check ($(echo "$PY_FILES" | wc -l | tr -d ' ') files)"
        for f in $PY_FILES; do
            if ! python3 -c "import ast; ast.parse(open('$f').read())" 2>/dev/null; then
                red "  ❌ Syntax error in $f"
                FAIL_COUNT=$((FAIL_COUNT + 1))
            fi
        done
        [ "$FAIL_COUNT" = "0" ] && green "  ✅ Syntax check passed"
    else
        echo "  ⏭  No .py files staged"
    fi
else
    echo "  ⏭  Stack not detected, skipping type check"
fi

echo ""

# ─────────────────────────────────────────────────────────────────────
# 2. docs-gate (v1 checks)
# ─────────────────────────────────────────────────────────────────────
blue "[2/3] docs-gate (v1: CHANGELOG + ARCHITECTURE 9 sections)"

if command -v docs-gate >/dev/null 2>&1 || command -v docs-gate.exe >/dev/null 2>&1; then
    echo "  → docs-gate"
    if ! docs-gate 2>&1; then
        red "  ❌ docs-gate failed"
        echo "     Run: docs-gate --verbose  for details"
        FAIL_COUNT=$((FAIL_COUNT + 1))
    else
        green "  ✅ docs-gate passed"
    fi
else
    yellow "  ⚠️  docs-gate binary not found — skipping v1 checks"
    WARN_COUNT=$((WARN_COUNT + 1))
fi

echo ""

# ─────────────────────────────────────────────────────────────────────
# 3. sos-kit v2 specific checks
# ─────────────────────────────────────────────────────────────────────
blue "[3/3] sos-kit v2 checks"

# 3a. BACKLOG.md must exist
if [ ! -f "docs/BACKLOG.md" ]; then
    yellow "  ⚠️  docs/BACKLOG.md missing"
    echo "     Bootstrap: cp ~/sos-kit/templates/BACKLOG_template.md docs/BACKLOG.md"
    WARN_COUNT=$((WARN_COUNT + 1))
else
    # 3b. Active sprint section must exist and not be empty
    # Find header line — strict match first (Active sprint), fallback to first ^## (P003 pattern)
    HEADER_LINE=$(grep -n "^## .*Active sprint" docs/BACKLOG.md 2>/dev/null | head -1 | cut -d: -f1)
    if [ -z "$HEADER_LINE" ]; then
        HEADER_LINE=$(grep -n "^## " docs/BACKLOG.md 2>/dev/null | head -1 | cut -d: -f1)
    fi
    # Get content AFTER the matched header until next "## " (excluding both headers)
    ACTIVE_SECTION=$(awk -v hdr="$HEADER_LINE" 'NR==hdr{found=1; next} found && /^## /{exit} found{print}' docs/BACKLOG.md)
    ACTIVE_ITEMS=$(echo "$ACTIVE_SECTION" | grep -c "^- \[" 2>/dev/null) || ACTIVE_ITEMS=0
    if [ "$ACTIVE_ITEMS" = "0" ]; then
        yellow "  ⚠️  BACKLOG.md Active sprint section is empty"
        echo "     Pick item từ Open backlog hoặc /idea thêm task vào Active sprint"
        WARN_COUNT=$((WARN_COUNT + 1))
    else
        green "  ✅ BACKLOG.md Active sprint has $ACTIVE_ITEMS items"
    fi
fi

# 3c. New phiếu file requires Discovery Report entry
NEW_PHIEU=$(git diff --cached --name-only --diff-filter=A | grep -E '^docs/ticket/P[0-9]+-' || true)
if [ -n "$NEW_PHIEU" ]; then
    echo "  → New phiếu detected: $NEW_PHIEU"
    DISCOVERIES_STAGED=$(git diff --cached --name-only --diff-filter=AM | grep -E '^docs/DISCOVERIES\.md$' || true)
    if [ -z "$DISCOVERIES_STAGED" ]; then
        red "  ❌ New phiếu committed but DISCOVERIES.md not updated"
        echo "     Architect/Worker must append a Discovery entry for this phiếu"
        echo "     Or this is a phiếu DRAFT (not done yet) → continue editing, commit later"
        FAIL_COUNT=$((FAIL_COUNT + 1))
    else
        # Verify the phiếu ID appears in DISCOVERIES.md
        for phieu in $NEW_PHIEU; do
            PHIEU_ID=$(basename "$phieu" .md | grep -oE 'P[0-9]+')
            if ! grep -q "## .*$PHIEU_ID" docs/DISCOVERIES.md 2>/dev/null; then
                red "  ❌ Phiếu $PHIEU_ID has no Discovery entry in DISCOVERIES.md"
                FAIL_COUNT=$((FAIL_COUNT + 1))
            else
                green "  ✅ Phiếu $PHIEU_ID has Discovery entry"
            fi
        done
    fi
fi

# 3d. Modified phiếu (existing) — only check Discovery if it's marked done somehow
# (Skip — phiếu drafts are common; only enforce on NEW phiếu file or explicit "completed" marker)

# 3e. Worker commit pattern: phiếu touched + code touched + Discovery touched = good signal
CODE_STAGED=$(git diff --cached --name-only --diff-filter=AM | grep -E '\.(py|rs|ts|tsx|js|jsx|go|java)$' | head -1 || true)
PHIEU_STAGED=$(git diff --cached --name-only --diff-filter=AM | grep -E '^docs/ticket/P[0-9]+-' || true)
if [ -n "$CODE_STAGED" ] && [ -n "$PHIEU_STAGED" ]; then
    DISCOVERIES_STAGED=$(git diff --cached --name-only --diff-filter=AM | grep -E '^docs/DISCOVERIES\.md$' || true)
    CHANGELOG_STAGED=$(git diff --cached --name-only --diff-filter=AM | grep -E '^docs/CHANGELOG\.md$' || true)
    if [ -z "$DISCOVERIES_STAGED" ] || [ -z "$CHANGELOG_STAGED" ]; then
        yellow "  ⚠️  Code + phiếu changed but DISCOVERIES.md or CHANGELOG.md not staged"
        echo "     Definition of Done requires both. Stage them: git add docs/DISCOVERIES.md docs/CHANGELOG.md"
        WARN_COUNT=$((WARN_COUNT + 1))
    fi
fi

echo ""

# ─────────────────────────────────────────────────────────────────────
# Summary
# ─────────────────────────────────────────────────────────────────────
echo "─────────────────────────────────────────────────────────────"
if [ "$FAIL_COUNT" = "0" ] && [ "$WARN_COUNT" = "0" ]; then
    green "✅ All checks passed."
elif [ "$FAIL_COUNT" = "0" ]; then
    yellow "⚠️  $WARN_COUNT warning(s). Commit allowed."
else
    red "❌ $FAIL_COUNT check(s) failed. Commit blocked."
    echo ""
    echo "Fix issues above, or use 'git commit --no-verify' to bypass (NOT recommended)."
    exit 1
fi
